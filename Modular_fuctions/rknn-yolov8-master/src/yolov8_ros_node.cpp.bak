#include <ros/ros.h>
#include <image_transport/image_transport.h>
#include <cv_bridge/cv_bridge.h>
#include <sensor_msgs/Image.h>
#include <vision_msgs/Detection2DArray.h>
#include <vision_msgs/Detection2D.h>
#include <vision_msgs/ObjectHypothesisWithPose.h>

#include <opencv2/opencv.hpp>

#include "task/yolov8.h"
#include "draw/cv_draw.h"
#include "types/datatype.h"

#include <atomic>
#include <thread>
#include <queue>
#include <mutex>
#include <condition_variable>

// ---------------------------------------------------------------------------
// Bounded queue for passing slot indices between pipeline stages
// ---------------------------------------------------------------------------
class BoundedQueue
{
public:
    explicit BoundedQueue(size_t capacity) : capacity_(capacity) {}

    void push(int item)
    {
        std::unique_lock<std::mutex> lock(mtx_);
        not_full_.wait(lock, [this] { return queue_.size() < capacity_ || shutdown_; });
        if (shutdown_) return;
        queue_.push(item);
        not_empty_.notify_one();
    }

    int pop()
    {
        std::unique_lock<std::mutex> lock(mtx_);
        not_empty_.wait(lock, [this] { return !queue_.empty() || shutdown_; });
        if (shutdown_) return -1;
        int item = queue_.front();
        queue_.pop();
        not_full_.notify_one();
        return item;
    }

    void shutdown()
    {
        {
            std::lock_guard<std::mutex> lock(mtx_);
            shutdown_ = true;
        }
        not_empty_.notify_all();
        not_full_.notify_all();
    }

private:
    std::queue<int> queue_;
    std::mutex mtx_;
    std::condition_variable not_empty_;
    std::condition_variable not_full_;
    size_t capacity_;
    bool shutdown_ = false;
};

// ---------------------------------------------------------------------------
// Pipeline constants
// ---------------------------------------------------------------------------
static constexpr int NUM_SLOTS = 2;

struct PipelineSlot
{
    cv::Mat raw_frame;                          // original camera frame
    tensor_data_s input_tensor;
    std::vector<tensor_data_s> output_tensors;
    cv::Mat letterbox_img;                      // preprocessed (letterbox + resize)
    LetterBoxInfo letterbox_info;
};

// ---------------------------------------------------------------------------
// Yolov8RosNode
// ---------------------------------------------------------------------------
class Yolov8RosNode
{
public:
    Yolov8RosNode(ros::NodeHandle &nh, ros::NodeHandle &pnh)
        : it_(nh)
        , free_queue_(NUM_SLOTS)
        , infer_queue_(1)
        , post_queue_(1)
    {
        mode_ = pnh.param("input_mode", std::string("camera"));
        camera_id_ = pnh.param("camera_id", 0);
        input_topic_ = pnh.param("input_topic", std::string("/camera/image_raw"));
        infer_width_ = pnh.param("infer_width", 1920);
        infer_height_ = pnh.param("infer_height", 1080);
        enable_display_ = pnh.param("enable_display", true);

        std::string model_path = pnh.param("model_path", std::string(""));
        if (model_path.empty())
        {
            ROS_ERROR("model_path is required");
            ros::shutdown();
            return;
        }

        // Thresholds
        float conf_thresh = pnh.param("score_threshold", 0.2);
        float nms_thresh = pnh.param("nms_threshold", 0.25);
        yolo_.SetObjectThreshold(conf_thresh);
        yolo_.SetNmsThreshold(nms_thresh);

        // Load model (this allocates the default buffers inside yolo_)
        if (yolo_.LoadModel(model_path.c_str()) != NN_ERROR_SUCCESS)
        {
            ROS_ERROR("Failed to load model: %s", model_path.c_str());
            ros::shutdown();
            return;
        }

        // Allocate ping-pong buffer slots using the model's tensor shapes
        auto input_shapes = yolo_.GetEngine()->GetInputShapes();
        auto output_shapes = yolo_.GetEngine()->GetOutputShapes();
        for (int i = 0; i < NUM_SLOTS; i++)
        {
            allocate_slot_buffers(input_shapes[0], output_shapes, yolo_.IsWantFloat(), slots_[i]);
        }

        // Push both slot indices into the free queue
        free_queue_.push(0);
        free_queue_.push(1);

        // Publishers
        img_pub_ = it_.advertise("/detect", 1);
        det_pub_ = nh.advertise<vision_msgs::Detection2DArray>("/yolo_msgs", 1);

        if (enable_display_)
        {
            cv::namedWindow("YOLOv8 Detection", cv::WINDOW_AUTOSIZE);
        }

        const int mw = yolo_.GetModelInputWidth();
        const int mh = yolo_.GetModelInputHeight();
        ROS_INFO("YOLOv8 ROS node started (mode=%s) | source/detect=%dx%d | RKNN model=%dx%d",
                 mode_.c_str(), infer_width_, infer_height_, mw, mh);
    }

    ~Yolov8RosNode()
    {
        stop();
    }

    void run()
    {
        running_ = true;

        // Always start the shared pipeline threads
        inference_thread_ = std::thread(&Yolov8RosNode::inferenceLoop, this);
        postprocess_thread_ = std::thread(&Yolov8RosNode::postprocessLoop, this);

        if (mode_ == "topic")
        {
            // Topic mode: ROS callbacks drive the capture stage
            img_sub_ = it_.subscribe(input_topic_, 1, &Yolov8RosNode::imageCallback, this);
            ros::spin();
        }
        else
        {
            // Camera mode: dedicated thread drives the capture stage
            capture_thread_ = std::thread(&Yolov8RosNode::captureLoop, this);
            ros::spin();
        }

        stop();
    }

private:
    // 将相机/话题图像统一到识别坐标系（默认 1920×1080）；NPU 仍用 640 模型 + letterbox
    void prepareInferFrame(cv::Mat &frame)
    {
        if (frame.cols != infer_width_ || frame.rows != infer_height_)
        {
            cv::resize(frame, frame, cv::Size(infer_width_, infer_height_), 0, 0, cv::INTER_LINEAR);
        }
    }

    // ---- Topic mode callback (pushes frame into pipeline) ----
    void imageCallback(const sensor_msgs::ImageConstPtr &msg)
    {
        try
        {
            cv::Mat frame = cv_bridge::toCvCopy(msg, "bgr8")->image;
            prepareInferFrame(frame);

            int slot = free_queue_.pop();
            if (slot < 0) return;

            slots_[slot].raw_frame = frame.clone();
            yolo_.AttachBuffers(slots_[slot].input_tensor, slots_[slot].output_tensors);
            yolo_.Preprocess(frame, slots_[slot].letterbox_img);
            slots_[slot].letterbox_info = yolo_.GetLetterBoxInfo();
            infer_queue_.push(slot);
        }
        catch (cv_bridge::Exception &e)
        {
            ROS_ERROR("cv_bridge error: %s", e.what());
        }
    }

    // ---- Pipeline: Thread 1 (Capture + Preprocess) ----
    void captureLoop()
    {
        cv::VideoCapture cap(camera_id_);
        if (!cap.isOpened())
        {
            ROS_ERROR("Failed to open camera: %d", camera_id_);
            running_ = false;
            return;
        }
        cap.set(cv::CAP_PROP_FRAME_WIDTH, infer_width_);
        cap.set(cv::CAP_PROP_FRAME_HEIGHT, infer_height_);
        ROS_INFO("Camera %d opened, requested %dx%d (actual %dx%d)",
                 camera_id_, infer_width_, infer_height_,
                 static_cast<int>(cap.get(cv::CAP_PROP_FRAME_WIDTH)),
                 static_cast<int>(cap.get(cv::CAP_PROP_FRAME_HEIGHT)));

        while (running_ && ros::ok())
        {
            cv::Mat frame;
            cap >> frame;
            if (frame.empty()) continue;

            prepareInferFrame(frame);

            int slot = free_queue_.pop();
            if (slot < 0) break;

            slots_[slot].raw_frame = frame.clone();

            // Attach this slot's buffers to the YOLO instance
            yolo_.AttachBuffers(slots_[slot].input_tensor, slots_[slot].output_tensors);

            // Preprocess (letterbox + tensor conversion)
            yolo_.Preprocess(frame, slots_[slot].letterbox_img);
            slots_[slot].letterbox_info = yolo_.GetLetterBoxInfo();

            // Pass to inference stage
            infer_queue_.push(slot);
        }

        infer_queue_.shutdown();
        cap.release();
    }

    // ---- Pipeline: Thread 2 (NPU Inference) ----
    void inferenceLoop()
    {
        while (running_)
        {
            int slot = infer_queue_.pop();
            if (slot < 0) break;

            // Attach the correct slot's buffers (Thread 1 may have changed them)
            yolo_.AttachBuffers(slots_[slot].input_tensor, slots_[slot].output_tensors);
            yolo_.Inference();

            // Pass to postprocess stage
            post_queue_.push(slot);
        }

        post_queue_.shutdown();
    }

    // ---- Pipeline: Thread 3 (Postprocess + Draw + Publish) ----
    void postprocessLoop()
    {
        while (running_)
        {
            int slot = post_queue_.pop();
            if (slot < 0) break;

            // Attach the correct slot's buffers (Thread 2 may have changed them)
            yolo_.AttachBuffers(slots_[slot].input_tensor, slots_[slot].output_tensors);

            // Postprocess
            std::vector<Detection> objects;
            yolo_.Postprocess(slots_[slot].letterbox_img, objects);

            letterbox_decode(objects, slots_[slot].letterbox_info.hor, slots_[slot].letterbox_info.pad);

            // Draw on original frame, then publish
            cv::Mat display = slots_[slot].raw_frame.clone();
            DrawDetections(display, objects);
            if (enable_display_)
            {
                cv::imshow("YOLOv8 Detection", display);
                cv::waitKey(1);
            }

            // Publish
            publish(display, objects);

            // Return slot to free pool
            free_queue_.push(slot);
        }
    }

    // ---- Publish results to ROS topics ----
    void publish(const cv::Mat &image, const std::vector<Detection> &objects)
    {
        // /detect (annotated image)
        sensor_msgs::ImagePtr img_msg =
            cv_bridge::CvImage(std_msgs::Header(), "bgr8", image).toImageMsg();
        img_msg->header.stamp = ros::Time::now();
        img_msg->header.frame_id = "camera_frame";
        img_pub_.publish(img_msg);

        // /yolo_msgs (detection array)
        vision_msgs::Detection2DArray det_array;
        det_array.header.stamp = ros::Time::now();
        det_array.header.frame_id = "camera_frame";
        det_array.detections.reserve(objects.size());

        for (const auto &obj : objects)
        {
            vision_msgs::Detection2D det;
            det.bbox.center.x = obj.box.x + obj.box.width / 2.0;
            det.bbox.center.y = obj.box.y + obj.box.height / 2.0;
            det.bbox.size_x = obj.box.width;
            det.bbox.size_y = obj.box.height;

            vision_msgs::ObjectHypothesisWithPose hyp;
            hyp.hypothesis.class_id = obj.class_id;
            hyp.hypothesis.score = obj.confidence;
            det.results.push_back(hyp);

            det_array.detections.push_back(det);
        }
        det_pub_.publish(det_array);
    }

    // ---- Allocate tensor buffers for a pipeline slot ----
    static void allocate_slot_buffers(
        const tensor_attr_s &input_attr,
        const std::vector<tensor_attr_s> &output_attrs,
        bool want_float,
        PipelineSlot &slot)
    {
        nn_tensor_attr_to_cvimg_input_data(input_attr, slot.input_tensor);
        slot.input_tensor.data = malloc(slot.input_tensor.attr.size);

        for (size_t i = 0; i < output_attrs.size(); i++)
        {
            tensor_data_s tensor;
            tensor.attr.n_elems = output_attrs[i].n_elems;
            tensor.attr.n_dims = output_attrs[i].n_dims;
            for (uint32_t j = 0; j < output_attrs[i].n_dims; j++)
            {
                tensor.attr.dims[j] = output_attrs[i].dims[j];
            }
            tensor.attr.type = want_float ? NN_TENSOR_FLOAT : output_attrs[i].type;
            tensor.attr.index = 0;
            tensor.attr.size = output_attrs[i].n_elems * nn_tensor_type_to_size(tensor.attr.type);
            tensor.data = malloc(tensor.attr.size);
            slot.output_tensors.push_back(tensor);
        }
    }

    // ---- Clean shutdown ----
    void stop()
    {
        if (!running_) return;
        running_ = false;

        free_queue_.shutdown();
        infer_queue_.shutdown();
        post_queue_.shutdown();

        if (capture_thread_.joinable()) capture_thread_.join();
        if (inference_thread_.joinable()) inference_thread_.join();
        if (postprocess_thread_.joinable()) postprocess_thread_.join();

        // Free slot buffers
        for (auto &slot : slots_)
        {
            if (slot.input_tensor.data) free(slot.input_tensor.data);
            for (auto &t : slot.output_tensors)
            {
                if (t.data) free(t.data);
            }
            slot.output_tensors.clear();
        }

        if (enable_display_)
        {
            cv::destroyWindow("YOLOv8 Detection");
        }
    }

    // ---- Members ----
    // ROS
    image_transport::ImageTransport it_;
    image_transport::Publisher img_pub_;
    ros::Publisher det_pub_;
    image_transport::Subscriber img_sub_;

    // YOLO
    Yolov8Custom yolo_;

    // Pipeline
    PipelineSlot slots_[NUM_SLOTS];
    BoundedQueue free_queue_;
    BoundedQueue infer_queue_;
    BoundedQueue post_queue_;

    std::thread capture_thread_;
    std::thread inference_thread_;
    std::thread postprocess_thread_;
    std::atomic<bool> running_{false};

    // Config
    std::string mode_;
    int camera_id_;
    std::string input_topic_;
    int infer_width_;
    int infer_height_;
    bool enable_display_;
};

int main(int argc, char **argv)
{
    ros::init(argc, argv, "yolov8_ros");
    ros::NodeHandle nh;
    ros::NodeHandle pnh("~");
    Yolov8RosNode node(nh, pnh);
    node.run();
    return 0;
}
