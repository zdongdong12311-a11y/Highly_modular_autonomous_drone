<launch>
    <!-- 640×640 RKNN 模型；源图/检测框坐标 1920×1080 -->
    <arg name="model_path"       default="$(find rknn_yolov8_ros)/weights/yolov8s_rk3588.rknn"/>
    <arg name="score_threshold"  default="0.25"/>
    <arg name="nms_threshold"    default="0.25"/>
    <arg name="camera_id"        default="0"/>
    <arg name="input_mode"       default="topic"/>
    <arg name="input_topic"      default="/camera/image_raw"/>
    <arg name="infer_width"      default="1920"/>
    <arg name="infer_height"     default="1080"/>
    <arg name="enable_display"   default="true"/>

    <node name="yolov8_ros" pkg="rknn_yolov8_ros" type="yolov8_ros_node" output="screen">
        <param name="model_path"      value="$(arg model_path)"/>
        <param name="score_threshold" value="$(arg score_threshold)"/>
        <param name="nms_threshold"   value="$(arg nms_threshold)"/>
        <param name="camera_id"       value="$(arg camera_id)"/>
        <param name="input_mode"      value="$(arg input_mode)"/>
        <param name="input_topic"     value="$(arg input_topic)"/>
        <param name="infer_width"     value="$(arg infer_width)"/>
        <param name="infer_height"    value="$(arg infer_height)"/>
        <param name="enable_display"  value="$(arg enable_display)"/>
    </node>
</launch>
