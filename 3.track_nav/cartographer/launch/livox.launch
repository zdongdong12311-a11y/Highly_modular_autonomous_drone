<launch>
   <param name="/use_sim_time" value="false" />
 
   <node name="cartographer_node" 
         pkg="cartographer_ros" 
         type="cartographer_node" 
         args="-configuration_directory $(dirname)/../lua -configuration_basename livox.lua"
         output="screen">
     <remap from="scan" to="/scan" />
     <remap from="odom" to="/mavros/local_position/odom" />
     <remap from="imu" to="/mavros/imu/data" />
   </node>
 
   <node name="cartographer_occupancy_grid_node" 
         pkg="cartographer_ros" 
         type="cartographer_occupancy_grid_node" 
         args="-resolution 0.05" />
   <!--<node name="rviz" 
         pkg="rviz" 
         type="rviz" 
         required="true" 
         args="-d $(find cartographer_ros)/configuration_files/demo_2d.rviz" />-->
   <!-- Cartographer owns map/odom/camera_init dynamic transforms. Keep only fixed body-frame transforms here. -->
   <!--<node pkg="tf" type="static_transform_publisher" name="odom_to_base_link" args="0 0 0 0 0 0 odom base_link 100"/>-->
   <!--<node pkg="tf" type="static_transform_publisher" name="base_link_to_camera_init" args="0 0 0 0 0 0 base_link camera_init 100"/>-->
   <node pkg="tf" type="static_transform_publisher" name="camera_init_to_base_link" args="0 0 0 0 0 0 camera_init base_link 100"/>

 </launch>
