<launch>
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <!-- <arg name="odom_topic" default="mavros/local_position/odom" /> -->
  <arg name="move_forward_only" default="false"/>
 
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen" clear_params="true" >
    <param name="base_global_planner" value="global_planner/GlobalPlanner" />
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS" />
    <rosparam file="$(dirname)/../yaml/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(dirname)/../yaml/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(dirname)/../yaml/local_costmap_params.yaml" command="load" />
    <rosparam file="$(dirname)/../yaml/global_costmap_params.yaml" command="load" />
    <rosparam file="$(dirname)/../yaml/move_base_params.yaml" command="load" />
    <rosparam file="$(dirname)/../yaml/dwa_local_planner_params.yaml" command="load" />
    <rosparam file="$(dirname)/../yaml/global_planner_params.yaml" command="load" />
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/> 
   
    <!-- <remap from="odom" to="$(arg odom_topic)"/> -->

    <param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)" />
    <param name="DWAPlannerROS/max_vel_y" value="0.0" if="$(arg move_forward_only)" />
    <param name="DWAPlannerROS/min_vel_y" value="0.0" if="$(arg move_forward_only)" />
  </node>
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(dirname)/../config/nav.rviz"/>
</launch>
